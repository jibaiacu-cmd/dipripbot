def print_report():
    if not DB_PATH.exists():
        print("Database belum ada. Jalankan bot dulu.")
        return

    conn = sqlite3.connect(str(DB_PATH))
    c    = conn.cursor()

    print("\n" + "═" * 65)
    print("  PAPER TRADE REPORT")
    print("═" * 65)

    c.execute("SELECT COUNT(*) FROM trades WHERE action='BUY'")
    buys = c.fetchone()[0]
    c.execute("SELECT COUNT(*) FROM trades WHERE action LIKE 'SELL%'")
    sells = c.fetchone()[0]
    print(f"  Total BUY  : {buys}")
    print(f"  Total SELL : {sells}")

    c.execute("SELECT SUM(pnl_sol),COUNT(*) FROM trades "
              "WHERE action LIKE 'SELL%' AND pnl_sol > 0")
    wr, wc = c.fetchone()
    c.execute("SELECT SUM(pnl_sol),COUNT(*) FROM trades "
              "WHERE action LIKE 'SELL%' AND pnl_sol <= 0")
    lr, lc = c.fetchone()
    wr, wc = (wr or 0), (wc or 0)
    lr, lc = (lr or 0), (lc or 0)
    total  = wc + lc
    rate   = wc / total * 100 if total > 0 else 0

    print(f"\n  Win rate   : {rate:.1f}%  ({wc}W / {lc}L)")
    print(f"  Net P&L    : {wr+lr:+.4f} SOL")
    print(f"  Profit     : +{wr:.4f} SOL")
    print(f"  Loss       :  {lr:.4f} SOL")

    # Equity curve ringkas
    c.execute("""
        SELECT date_str, MAX(equity_sol), MIN(equity_sol)
        FROM equity_log GROUP BY date_str ORDER BY date_str
    """)
    rows = c.fetchall()
    if rows:
        print(f"\n  {'Tanggal':<12} {'Max Equity':>12} {'Min Equity':>12}")
        print("  " + "-" * 38)
        for dt, hi, lo in rows:
            print(f"  {dt:<12} {hi:>12.4f} {lo:>12.4f}")

    # 10 trade terakhir
    c.execute("""
        SELECT date_str, action, symbol, tier, grade, pnl_sol, pnl_pct
        FROM trades WHERE action LIKE 'SELL%'
        ORDER BY ts DESC LIMIT 10
    """)
    rows = c.fetchall()
    if rows:
        print(f"\n  10 trade terakhir:")
        print(f"  {'Tgl':<12} {'Aksi':<12} {'Token':<10} "
              f"{'Tier':<5} {'Grade':<6} {'SOL':>9} {'%':>7}")
        print("  " + "-" * 60)
        for r in rows:
            psol = r[5] or 0
            ppct = r[6] or 0
            em   = "✅" if psol > 0 else "❌"
            print(f"  {r[0]:<12} {em}{r[1]:<11} {r[2]:<10} "
                  f"{r[3]:<5} {r[4]:<6} {psol:>+9.4f} {ppct:>+6.1f}%")

    print("═" * 65 + "\n")
    conn.close()


if __name__ == "__main__":
    print_report()
