# SECTION 9: EXECUTION ENGINE (orkestrator)
# ══════════════════════════════════════════════════════════════════════

class ExecutionEngine:
    """
    Orkestrator utama. Interface ke bot_v11.py:
      engine.on_signal(signal)   — sinyal entry baru
      engine.run_exit_checks()   — cek exit tiap scan
      engine.start()             — start kill switch
      engine.paused              — True = tahan order baru
    """

    def __init__(self):
        self.mode          = "paper" if PAPER_TRADE else "live"
        self.paused        = False
        self.paper_balance = [PAPER_INITIAL_BALANCE]  # mutable ref

        # DB
        self.conn = sqlite3.connect(str(DB_PATH), check_same_thread=False)
        init_db(self.conn)

        # Komponen
        self.risk      = RiskGuard(self.conn, self.paper_balance)
        self.positions = PositionTracker(self.conn)
        self.ks        = KillSwitch(self)
        self.executor  = PaperExecutor() if PAPER_TRADE else LiveExecutor()

        self._lock = threading.Lock()

        mode_label = "PAPER TRADE" if PAPER_TRADE else "LIVE TRADING ⚠️"
        print(f"[ENGINE] Mode: {mode_label}")
        if PAPER_TRADE:
            print(f"[ENGINE] Saldo simulasi: {PAPER_INITIAL_BALANCE} SOL")

    # ── start ─────────────────────────────────────────────────────────

    def start(self):
        """Dipanggil dari bot_v11.main()."""
        self.ks.start()
        mode_str = "📄 PAPER TRADE" if PAPER_TRADE else "🔴 LIVE TRADING ⚠️"
        send_tg(
            f"⚙️ <b>Execution Engine aktif</b>\n\n"
            f"Mode: <b>{mode_str}</b>\n"
            f"{'Saldo simulasi: ' + str(PAPER_INITIAL_BALANCE) + ' SOL' if PAPER_TRADE else ''}\n\n"
            f"<b>Risk parameters:</b>\n"
            f"  Max per trade  : {MAX_SOL_PER_TRADE} SOL\n"
            f"  Max exposure   : {MAX_TOTAL_EXPOSURE} SOL\n"
            f"  Circuit breaker: -{MAX_DAILY_LOSS_SOL} SOL/hari\n"
            f"  Max posisi     : {MAX_OPEN_POSITIONS}\n\n"
            f"Kill switch:\n"
            f"  /pause /resume /stop /status /balance"
        )

    # ── entry signal ──────────────────────────────────────────────────

    def on_signal(self, signal: dict):
        """
        Dipanggil saat bot_v11 menemukan sinyal entry baru.
        Alur: risk check → sizing → buy → catat → notif
        """
        if self.paused:
            print(f"[ENGINE] Paused — skip {signal.get('symbol')}")
            return

        with self._lock:
            sym  = signal.get("symbol", "?")
            tier = signal.get("tier", "T1")

            # ── sizing ────────────────────────────────────────────────
            mult          = POSITION_SIZE_BY_TIER.get(tier, 0.8)
            sol_to_invest = round(MAX_SOL_PER_TRADE * mult, 6)

            # ── risk check ────────────────────────────────────────────
            ok, reason = self.risk.check(signal, sol_to_invest)
            if not ok:
                print(f"[RISK BLOCK] {sym} — {reason}")
                log_error(self.conn, "RiskGuard", f"Blocked {sym}", reason)
                return

            # ── eksekusi BUY ──────────────────────────────────────────
            print(f"[ENGINE] BUY {sym} | {tier} | {sol_to_invest:.4f} SOL")
            try:
                res = self.executor.buy(
                    token_addr=signal.get("addr", ""),
                    symbol=sym,
                    price_usd=signal.get("price", 0),
                    sol_amount=sol_to_invest,
                )
            except Exception as e:
                log_error(self.conn, "buy", str(e), sym)
                print(f"[ENGINE ERR] Buy exception: {e}")
                return

            if not res.get("ok"):
                log_error(self.conn, "buy", res.get("error", "?"), sym)
                print(f"[ENGINE] Buy gagal: {res.get('error')}")
                return

            # ── update saldo paper ────────────────────────────────────
            if PAPER_TRADE:
                self.paper_balance[0] -= res["sol_spent"]

            # ── catat ke DB ───────────────────────────────────────────
            self._log_trade(
                action="BUY", signal=signal,
                price_exec=res["exec_price"],
                sol_amount=res["sol_spent"],
                token_amount=res["token_amount"],
                tx_hash=res.get("tx_hash"),
            )

            # ── buka posisi ───────────────────────────────────────────
            self.positions.open_position(
                signal=signal,
                sol_invested=res["sol_spent"],
                token_amount=res["token_amount"],
                mode=self.mode,
            )

            # ── notifikasi ────────────────────────────────────────────
            sol_px  = get_sol_price_usd() or 1
            usd_val = res["sol_spent"] * sol_px
            send_tg(
                f"{'📄' if PAPER_TRADE else '🟢'} "
                f"<b>ORDER TEREKSEKUSI</b>\n\n"
                f"🪙 <b>{sym}</b> | {tier} | Grade {signal.get('grade')}\n"
                f"💰 Beli : <b>{res['sol_spent']:.4f} SOL</b> "
                f"(≈${usd_val:.2f})\n"
                f"💹 Harga: <b>${res['exec_price']:.8f}</b>\n"
                f"🎯 Token: {res['token_amount']:.4f}\n\n"
                f"🔴 SL : ${signal.get('sl', 0):.8f}\n"
                f"🟡 TP1: ${signal.get('tp1', 0):.8f} — jual 50%\n"
                f"🟢 TP2: ${signal.get('tp2', 0):.8f} — jual sisanya\n\n"
                f"{'<i>[SIMULASI — tidak ada tx nyata]</i>' if PAPER_TRADE else ''}"
            )
            self._log_equity()

    # ── exit checks ───────────────────────────────────────────────────

    def run_exit_checks(self):
        """Dipanggil tiap scan. Periksa semua posisi: SL/TP1/TP2/Trailing."""
        for pos in self.positions.get_all():
            try:
                self._check_position(pos)
            except Exception as e:
                log_error(self.conn, "exit_check", str(e),
                          pos.get("token_addr", ""))

    def _check_position(self, pos: dict):
        addr        = pos["token_addr"]
        sym         = pos["symbol"]
        entry       = pos["entry_price"]
        sl          = pos["sl_price"]
        tp1         = pos["tp1_price"]
        tp2         = pos["tp2_price"]
        tp1_hit     = bool(pos["tp1_hit"])
        t_high      = pos["tracked_high"]
        trailing    = pos.get("trailing_sl")
        tokens_rem  = pos["token_amount_remaining"]
        sol_inv     = pos["sol_invested"]

        price_now = get_token_price_usd(addr)
        if price_now <= 0:
            return

        # update tracked high
        if price_now > t_high:
            self.positions.update_tracked_high(addr, price_now)
            t_high = price_now

        # ── trailing SL ───────────────────────────────────────────────
        profit_pct = (price_now / entry - 1) * 100
        if profit_pct >= TRAILING_ACTIVATE_PCT:
            new_trail = price_now * (1 - TRAILING_SL_PCT / 100)
            if trailing is None or new_trail > trailing:
                old_sl = sl
                self.positions.update_trailing_sl(addr, new_trail)
                sl = trailing = new_trail
                send_tg(
                    f"🔄 <b>TRAILING SL UPDATE</b>"
                    f"{'📄' if PAPER_TRADE else ''}\n\n"
                    f"🪙 <b>{sym}</b>\n"
                    f"💹 Harga: ${price_now:.8f}\n"
                    f"SL lama: ${old_sl:.8f}\n"
                    f"🔴 SL baru: <b>${new_trail:.8f}</b>\n"
                    f"📈 Profit: +{profit_pct:.1f}%"
                )

        # ── SL hit ────────────────────────────────────────────────────
        if price_now <= sl:
            pnl_pct = (price_now / entry - 1) * 100
            self._do_sell(pos, price_now, tokens_rem, "SELL_SL", pnl_pct)
            return

        # ── TP2 hit ───────────────────────────────────────────────────
        if price_now >= tp2 and not pos.get("tp2_hit"):
            pnl_pct = (price_now / entry - 1) * 100
            self._do_sell(pos, price_now, tokens_rem, "SELL_TP2", pnl_pct)
            return

        # ── TP1 hit — partial 50% ─────────────────────────────────────
        if price_now >= tp1 and not tp1_hit:
            pnl_pct        = (price_now / entry - 1) * 100
            tokens_to_sell = pos["token_amount"] * 0.50
            self._do_partial_sell(pos, price_now, tokens_to_sell, pnl_pct)

    # ── sell helpers ──────────────────────────────────────────────────

    def _do_sell(self, pos: dict, price_now: float,
                 token_amount: float, action: str, pnl_pct: float):
        """Full sell — SL atau TP2."""
        sym = pos["symbol"]
        print(f"[ENGINE] {action} {sym} @ ${price_now:.8f} ({pnl_pct:+.1f}%)")

        try:
            res = self.executor.sell(
                token_addr=pos["token_addr"], symbol=sym,
                price_usd=price_now, token_amount=token_amount,
            )
        except Exception as e:
            log_error(self.conn, "sell", str(e), sym)
            return

        if not res.get("ok"):
            log_error(self.conn, "sell", res.get("error", "?"), sym)
            return

        sol_recv = res["sol_received"]
        pnl_sol  = sol_recv - pos["sol_invested"]

        if PAPER_TRADE:
            self.paper_balance[0] += sol_recv

        sig_stub = {
            "addr": pos["token_addr"], "symbol": sym,
            "tier": pos["tier"],       "grade":  pos["grade"],
            "price": price_now,
            "sl": pos["sl_price"], "tp1": pos["tp1_price"],
            "tp2": pos["tp2_price"],
        }
        self._log_trade(
            action=action, signal=sig_stub,
            price_exec=res["exec_price"],
            sol_amount=sol_recv, token_amount=token_amount,
            pnl_sol=pnl_sol, pnl_pct=pnl_pct,
            entry_price=pos["entry_price"],
            tx_hash=res.get("tx_hash"),
        )
        self.positions.close(pos["token_addr"])

        emoji    = "⛔" if action == "SELL_SL" else "🟢"
        label    = "STOP LOSS" if action == "SELL_SL" else "TP2 TERCAPAI"
        send_tg(
            f"{emoji} <b>{label}</b>"
            f"{'📄' if PAPER_TRADE else ''}\n\n"
            f"🪙 <b>{sym}</b> | {pos['tier']}\n"
            f"💹 Harga exec: ${res['exec_price']:.8f}\n"
            f"💰 Terima: {sol_recv:.4f} SOL\n"
            f"📊 P&amp;L: <b>{pnl_sol:+.4f} SOL ({pnl_pct:+.1f}%)</b>\n"
            f"💼 Saldo: {self.paper_balance[0]:.4f} SOL\n"
            f"{'<i>[SIMULASI]</i>' if PAPER_TRADE else ''}"
        )
        self._log_equity()

    def _do_partial_sell(self, pos: dict, price_now: float,
                         tokens_to_sell: float, pnl_pct: float):
        """Partial sell 50% saat TP1 hit."""
        sym = pos["symbol"]
        print(f"[ENGINE] SELL_TP1 (50%) {sym} @ ${price_now:.8f}")

        try:
            res = self.executor.sell(
                token_addr=pos["token_addr"], symbol=sym,
                price_usd=price_now, token_amount=tokens_to_sell,
            )
        except Exception as e:
            log_error(self.conn, "sell_partial", str(e), sym)
            return

        if not res.get("ok"):
            return

        sol_recv     = res["sol_received"]
        pnl_sol_half = sol_recv - pos["sol_invested"] * 0.50

        if PAPER_TRADE:
            self.paper_balance[0] += sol_recv

        sig_stub = {
            "addr": pos["token_addr"], "symbol": sym,
            "tier": pos["tier"],       "grade":  pos["grade"],
            "price": price_now,
            "sl": pos["sl_price"], "tp1": pos["tp1_price"],
            "tp2": pos["tp2_price"],
        }
        self._log_trade(
            action="SELL_TP1", signal=sig_stub,
            price_exec=res["exec_price"],
            sol_amount=sol_recv, token_amount=tokens_to_sell,
            pnl_sol=pnl_sol_half, pnl_pct=pnl_pct,
            entry_price=pos["entry_price"],
            tx_hash=res.get("tx_hash"),
            note="partial 50%",
        )
        self.positions.mark_tp1_hit(pos["token_addr"], tokens_to_sell)

        send_tg(
            f"🟡 <b>TP1 TERCAPAI — jual 50%</b>"
            f"{'📄' if PAPER_TRADE else ''}\n\n"
            f"🪙 <b>{sym}</b> | {pos['tier']}\n"
            f"💹 Harga exec: ${res['exec_price']:.8f}\n"
            f"💰 Terima: {sol_recv:.4f} SOL (50%)\n"
            f"📊 P&amp;L parsial: "
            f"<b>{pnl_sol_half:+.4f} SOL ({pnl_pct:+.1f}%)</b>\n\n"
            f"📌 50% sisa menunggu TP2: ${pos['tp2_price']:.8f}\n"
            f"🔴 SL aktif: ${pos['sl_price']:.8f}\n"
            f"{'<i>[SIMULASI]</i>' if PAPER_TRADE else ''}"
        )
        self._log_equity()

    # ── DB helpers ────────────────────────────────────────────────────

    def _log_trade(self, action: str, signal: dict,
                   price_exec: float, sol_amount: float, token_amount: float,
                   pnl_sol: float = None, pnl_pct: float = None,
                   entry_price: float = None, tx_hash: str = None,
                   note: str = ""):
        c = self.conn.cursor()
        c.execute("""
            INSERT INTO trades
            (ts, date_str, mode, action, token_addr, symbol, tier, grade,
             price_usd, sol_amount, token_amount, entry_price,
             pnl_sol, pnl_pct, tx_hash, note)
            VALUES (?,?,?,?,?,?,?,?,?,?,?,?,?,?,?,?)
        """, (
            time.time(), date.today().isoformat(), self.mode,
            action, signal.get("addr",""), signal.get("symbol",""),
            signal.get("tier",""), signal.get("grade",""),
            price_exec, sol_amount, token_amount,
            entry_price, pnl_sol, pnl_pct, tx_hash, note,
        ))
        self.conn.commit()

    def _log_equity(self):
        pos_list  = self.positions.get_all()
        exposure  = sum(p["sol_invested"] for p in pos_list)
        c = self.conn.cursor()
        c.execute("""
            INSERT INTO equity_log
            (ts, date_str, equity_sol, balance_sol,
             open_positions, daily_pnl_sol, mode)
            VALUES (?,?,?,?,?,?,?)
        """, (
            time.time(), date.today().isoformat(),
            self.paper_balance[0] + exposure,
            self.paper_balance[0],
            len(pos_list),
            self.risk.daily_pnl(),
            self.mode,
        ))
        self.conn.commit()

    # ── status ────────────────────────────────────────────────────────

    def status_summary(self) -> str:
        pos_list  = self.positions.get_all()
        bal       = self.paper_balance[0]
        dpnl      = self.risk.daily_pnl()
        exp       = self.risk.total_exposure()
        mode_str  = "📄 Paper" if PAPER_TRADE else "🔴 Live"
        pause_str = " | ⏸ PAUSED" if self.paused else ""

        lines = ""
        for p in pos_list:
            px  = get_token_price_usd(p["token_addr"])
            pnl = (px / p["entry_price"] - 1) * 100 if px > 0 else 0
            lines += (f"\n  • {p['symbol']} {p['tier']} "
                      f"| {p['sol_invested']:.3f} SOL | {pnl:+.1f}%")

        return (
            f"Mode: {mode_str}{pause_str}\n\n"
            f"💰 Saldo: {bal:.4f} SOL\n"
            f"📊 Exposure: {exp:.4f} SOL\n"
            f"📈 P&amp;L hari ini: {dpnl:+.4f} SOL\n\n"
            f"Posisi terbuka ({len(pos_list)}/{MAX_OPEN_POSITIONS}):"
            f"{lines if lines else chr(10) + '  (kosong)'}"
        )


