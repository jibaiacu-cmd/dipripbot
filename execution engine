class RiskGuard:
    """
    Semua pengecekan risk sebelum order dieksekusi.
    check() → (ok: bool, reason: str)
    """

    def __init__(self, conn: sqlite3.Connection, paper_balance: list):
        self.conn          = conn
        self.paper_balance = paper_balance   # mutable [float]
        self._lock         = threading.Lock()

    # ── internal helpers ──────────────────────────────────────────────

    def open_count(self) -> int:
        c = self.conn.cursor()
        c.execute("SELECT COUNT(*) FROM positions")
        return c.fetchone()[0]

    def total_exposure(self) -> float:
        c = self.conn.cursor()
        c.execute("SELECT SUM(sol_invested) FROM positions")
        row = c.fetchone()
        return float(row[0] or 0)

    def daily_pnl(self) -> float:
        today = date.today().isoformat()
        c = self.conn.cursor()
        c.execute(
            "SELECT SUM(pnl_sol) FROM trades "
            "WHERE date_str=? AND action LIKE 'SELL%'",
            (today,))
        row = c.fetchone()
        return float(row[0] or 0)

    def already_open(self, token_addr: str) -> bool:
        c = self.conn.cursor()
        c.execute("SELECT 1 FROM positions WHERE token_addr=?", (token_addr,))
        return c.fetchone() is not None

    # ── main check ────────────────────────────────────────────────────

    def check(self, signal: dict, sol_to_invest: float) -> tuple:
        with self._lock:
            tier   = signal.get("tier", "T1")
            grade  = signal.get("grade", "B")
            addr   = signal.get("addr", "")
            symbol = signal.get("symbol", "?")

            # R1: Grade minimum per tier
            min_grade = EXEC_MIN_GRADE.get(tier, "B")
            if GRADE_ORDER.get(grade, 0) < GRADE_ORDER.get(min_grade, 3):
                return False, (f"R1: Grade {grade} di bawah minimum "
                               f"{min_grade} untuk {tier}")

            # R2: Posisi token ini sudah terbuka
            if self.already_open(addr):
                return False, f"R2: Posisi {symbol} sudah terbuka"

            # R3: Jumlah posisi maks
            if self.open_count() >= MAX_OPEN_POSITIONS:
                return False, (f"R3: Maks posisi terbuka "
                               f"({MAX_OPEN_POSITIONS}) sudah tercapai")

            # R4: Total exposure
            exp = self.total_exposure()
            if exp + sol_to_invest > MAX_TOTAL_EXPOSURE:
                return False, (f"R4: Exposure {exp:.3f}+{sol_to_invest:.3f} "
                               f"> max {MAX_TOTAL_EXPOSURE} SOL")

            # R5: Circuit breaker harian
            dpnl = self.daily_pnl()
            if dpnl <= -MAX_DAILY_LOSS_SOL:
                return False, (f"R5: Circuit breaker — rugi hari ini "
                               f"{dpnl:.4f} SOL ≤ -{MAX_DAILY_LOSS_SOL} SOL")

            # R6: Saldo cukup
            bal = self.paper_balance[0]
            if bal - sol_to_invest < MIN_SOL_RESERVE:
                return False, (f"R6: Saldo tidak cukup — "
                               f"balance {bal:.4f}, "
                               f"butuh {sol_to_invest:.4f} + "
                               f"{MIN_SOL_RESERVE:.4f} reserve")

            # R7: Order minimum
            if sol_to_invest < 0.001:
                return False, f"R7: Order terlalu kecil ({sol_to_invest:.4f} SOL)"

            return True, "OK"


