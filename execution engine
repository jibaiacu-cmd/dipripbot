def init_db(conn: sqlite3.Connection):
    """Buat semua tabel jika belum ada. Dipanggil saat engine startup."""
    c = conn.cursor()

    # trades — setiap aksi buy / sell
    c.execute("""
        CREATE TABLE IF NOT EXISTS trades (
            id            INTEGER PRIMARY KEY AUTOINCREMENT,
            ts            REAL    NOT NULL,
            date_str      TEXT    NOT NULL,
            mode          TEXT    NOT NULL,
            action        TEXT    NOT NULL,
            token_addr    TEXT    NOT NULL,
            symbol        TEXT    NOT NULL,
            tier          TEXT    NOT NULL,
            grade         TEXT    NOT NULL,
            price_usd     REAL    NOT NULL,
            sol_amount    REAL    NOT NULL,
            token_amount  REAL    NOT NULL,
            entry_price   REAL,
            pnl_sol       REAL,
            pnl_pct       REAL,
            tx_hash       TEXT,
            note          TEXT
        )
    """)

    # positions — posisi terbuka saat ini
    c.execute("""
        CREATE TABLE IF NOT EXISTS positions (
            token_addr             TEXT PRIMARY KEY,
            symbol                 TEXT NOT NULL,
            tier                   TEXT NOT NULL,
            grade                  TEXT NOT NULL,
            entry_price            REAL NOT NULL,
            entry_ts               REAL NOT NULL,
            sol_invested           REAL NOT NULL,
            token_amount           REAL NOT NULL,
            token_amount_remaining REAL NOT NULL,
            sl_price               REAL NOT NULL,
            tp1_price              REAL NOT NULL,
            tp2_price              REAL NOT NULL,
            tp1_hit                INTEGER NOT NULL DEFAULT 0,
            tp2_hit                INTEGER NOT NULL DEFAULT 0,
            tracked_high           REAL NOT NULL,
            trailing_sl            REAL,
            mode                   TEXT NOT NULL
        )
    """)

    # equity_log — snapshot equity tiap akhir scan
    c.execute("""
        CREATE TABLE IF NOT EXISTS equity_log (
            id             INTEGER PRIMARY KEY AUTOINCREMENT,
            ts             REAL    NOT NULL,
            date_str       TEXT    NOT NULL,
            equity_sol     REAL    NOT NULL,
            balance_sol    REAL    NOT NULL,
            open_positions INTEGER NOT NULL,
            daily_pnl_sol  REAL    NOT NULL,
            mode           TEXT    NOT NULL
        )
    """)

    # errors — semua error runtime
    c.execute("""
        CREATE TABLE IF NOT EXISTS errors (
            id        INTEGER PRIMARY KEY AUTOINCREMENT,
            ts        REAL NOT NULL,
            component TEXT NOT NULL,
            message   TEXT NOT NULL,
            detail    TEXT
        )
    """)

    conn.commit()
    print("[DB] Database siap →", DB_PATH)


