class PositionTracker:
    """Kelola semua posisi terbuka. Satu-satunya sumber kebenaran posisi."""

    def __init__(self, conn: sqlite3.Connection):
        self.conn  = conn
        self._lock = threading.Lock()

    def open_position(self, signal: dict, sol_invested: float,
                      token_amount: float, mode: str):
        with self._lock:
            c = self.conn.cursor()
            c.execute("""
                INSERT OR REPLACE INTO positions
                (token_addr, symbol, tier, grade,
                 entry_price, entry_ts, sol_invested,
                 token_amount, token_amount_remaining,
                 sl_price, tp1_price, tp2_price,
                 tp1_hit, tp2_hit, tracked_high, trailing_sl, mode)
                VALUES (?,?,?,?,?,?,?,?,?,?,?,?,0,0,?,NULL,?)
            """, (
                signal["addr"],    signal["symbol"],
                signal["tier"],    signal["grade"],
                signal["price"],   time.time(),
                sol_invested,      token_amount,
                token_amount,                        # remaining = full
                signal["sl"],      signal["tp1"],
                signal["tp2"],     signal["price"],  # tracked_high = entry
                mode,
            ))
            self.conn.commit()
            print(f"[POS OPEN] {signal['symbol']} "
                  f"{sol_invested:.4f} SOL @ ${signal['price']:.8f}")

    def get_all(self) -> list:
        c = self.conn.cursor()
        c.execute("SELECT * FROM positions")
        cols = [d[0] for d in c.description]
        return [dict(zip(cols, row)) for row in c.fetchall()]

    def update_tracked_high(self, token_addr: str, price: float):
        with self._lock:
            self.conn.execute(
                "UPDATE positions SET tracked_high=MAX(tracked_high,?) "
                "WHERE token_addr=?", (price, token_addr))
            self.conn.commit()

    def update_trailing_sl(self, token_addr: str, new_sl: float):
        with self._lock:
            self.conn.execute(
                "UPDATE positions "
                "SET trailing_sl=?, sl_price=MAX(sl_price,?) "
                "WHERE token_addr=?",
                (new_sl, new_sl, token_addr))
            self.conn.commit()

    def mark_tp1_hit(self, token_addr: str, tokens_sold: float):
        with self._lock:
            self.conn.execute(
                "UPDATE positions "
                "SET tp1_hit=1, "
                "token_amount_remaining=token_amount_remaining-? "
                "WHERE token_addr=?",
                (tokens_sold, token_addr))
            self.conn.commit()

    def close(self, token_addr: str):
        with self._lock:
            self.conn.execute(
                "DELETE FROM positions WHERE token_addr=?", (token_addr,))
            self.conn.commit()
            print(f"[POS CLOSE] {token_addr[:12]}...")


