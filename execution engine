class PaperExecutor:
    """
    Simulasi eksekusi tanpa transaksi on-chain.
    Mensimulasikan slippage realistis dan latency.
    """

    def buy(self, token_addr: str, symbol: str,
            price_usd: float, sol_amount: float) -> dict:
        time.sleep(0.3)   # simulasi latency

        exec_price   = price_usd * (1 + PAPER_SLIPPAGE_BUY_PCT / 100)
        sol_price    = get_sol_price_usd()
        if sol_price <= 0:
            return {"ok": False, "error": "Harga SOL tidak tersedia"}

        usd_to_spend = sol_amount * sol_price
        token_amount = usd_to_spend / exec_price

        print(f"[PAPER BUY]  {symbol} | {sol_amount:.4f} SOL → "
              f"{token_amount:.4f} token @ ${exec_price:.8f} "
              f"(slip {PAPER_SLIPPAGE_BUY_PCT}%)")
        return {
            "ok": True, "token_amount": token_amount,
            "exec_price": exec_price, "sol_spent": sol_amount,
            "tx_hash": None,
        }

    def sell(self, token_addr: str, symbol: str,
             price_usd: float, token_amount: float) -> dict:
        time.sleep(0.3)

        exec_price   = price_usd * (1 - PAPER_SLIPPAGE_SELL_PCT / 100)
        sol_price    = get_sol_price_usd()
        if sol_price <= 0:
            return {"ok": False, "error": "Harga SOL tidak tersedia"}

        usd_received = token_amount * exec_price
        sol_received = usd_received / sol_price

        print(f"[PAPER SELL] {symbol} | {token_amount:.4f} token → "
              f"{sol_received:.4f} SOL @ ${exec_price:.8f} "
              f"(slip {PAPER_SLIPPAGE_SELL_PCT}%)")
        return {
            "ok": True, "sol_received": sol_received,
            "exec_price": exec_price, "tx_hash": None,
        }


