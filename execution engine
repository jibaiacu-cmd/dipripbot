class KillSwitch:
    """
    Telegram listener di thread terpisah.
    Hanya menerima command dari CHAT_ID yang diizinkan.

    Commands:
      /pause   — stop order baru, posisi aktif tetap dipantau
      /resume  — lanjut order baru
      /stop    — pause + kirim ringkasan posisi
      /status  — ringkasan akun
      /balance — saldo paper/live
    """

    def __init__(self, engine):
        self.engine   = engine
        self._offset  = 0
        self._running = False

    def start(self):
        self._running = True
        t = threading.Thread(target=self._loop, daemon=True, name="KillSwitch")
        t.start()
        print("[KILL SWITCH] Aktif — mendengarkan Telegram command")

    def stop(self):
        self._running = False

    def _loop(self):
        while self._running:
            try:
                self._poll()
            except Exception as e:
                print(f"[KILL SWITCH ERR] {e}")
            time.sleep(3)

    def _poll(self):
        if not BOT_TOKEN:
            return
        r = requests.get(
            f"https://api.telegram.org/bot{BOT_TOKEN}"
            f"/getUpdates?offset={self._offset}&timeout=2",
            timeout=6)
        if r.status_code != 200:
            return
        for upd in r.json().get("result", []):
            self._offset = upd["update_id"] + 1
            msg = upd.get("message", {})
            # Abaikan pesan dari chat lain
            if str(msg.get("chat", {}).get("id")) != str(CHAT_ID):
                continue
            text = (msg.get("text") or "").strip().lower()
            self._handle(text.split()[0] if text else "")

    def _handle(self, cmd: str):
        if   cmd == "/pause":   self._pause()
        elif cmd == "/resume":  self._resume()
        elif cmd == "/stop":    self._stop()
        elif cmd == "/status":  self._status()
        elif cmd == "/balance": self._balance()

    def _pause(self):
        self.engine.paused = True
        mode = "📄 PAPER" if PAPER_TRADE else "🔴 LIVE"
        send_tg(f"⏸ <b>Bot di-pause</b>\n\nMode: {mode}\n"
                f"Posisi aktif tetap dipantau.\n"
                f"Order baru: DITAHAN\n\nKirim /resume untuk lanjut.")
        print("[KILL SWITCH] PAUSED")

    def _resume(self):
        self.engine.paused = False
        send_tg("▶️ <b>Bot di-resume</b>\n\nOrder baru: AKTIF")
        print("[KILL SWITCH] RESUMED")

    def _stop(self):
        self.engine.paused = True
        send_tg(f"🛑 <b>Bot di-STOP</b>\n\n"
                f"{self.engine.status_summary()}\n\n"
                f"Kirim /resume untuk lanjut.")
        print("[KILL SWITCH] STOPPED")

    def _status(self):
        send_tg(f"📊 <b>Status Bot</b>\n\n{self.engine.status_summary()}")

    def _balance(self):
        bal  = self.engine.paper_balance[0]
        pnl  = bal - PAPER_INITIAL_BALANCE
        mode = "📄 Paper" if PAPER_TRADE else "🔴 Live"
        send_tg(f"💰 <b>Balance ({mode})</b>\n\n"
                f"Saldo: <b>{bal:.4f} SOL</b>\n"
                f"Awal:  {PAPER_INITIAL_BALANCE:.4f} SOL\n"
                f"P&amp;L: <b>{pnl:+.4f} SOL "
                f"({pnl/PAPER_INITIAL_BALANCE*100:+.1f}%)</b>")


