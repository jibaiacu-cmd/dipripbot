_sol_price_cache = {"price": 0.0, "ts": 0.0}

def get_sol_price_usd() -> float:
    """Harga SOL/USD dari DexScreener. Cache 60 detik."""
    now = time.time()
    if now - _sol_price_cache["ts"] < 60 and _sol_price_cache["price"] > 0:
        return _sol_price_cache["price"]
    try:
        SOL_MINT = "So11111111111111111111111111111111111111112"
        r = requests.get(
            f"https://api.dexscreener.com/latest/dex/tokens/{SOL_MINT}",
            timeout=8)
        if r.status_code == 200:
            pairs = r.json().get("pairs", [])
            sol_pairs = [p for p in pairs
                         if p.get("quoteToken", {}).get("symbol", "")
                         in ("USDC", "USDT", "USD")]
            if sol_pairs:
                best = max(sol_pairs,
                           key=lambda x: x.get("volume", {}).get("h24", 0))
                price = float(best.get("priceUsd", 0) or 0)
                if price > 0:
                    _sol_price_cache["price"] = price
                    _sol_price_cache["ts"]    = now
                    return price
    except Exception as e:
        print(f"[SOL PRICE ERR] {e}")
    return _sol_price_cache["price"]


def get_token_price_usd(token_addr: str) -> float:
    """Harga token saat ini dari DexScreener. Return 0 jika gagal."""
    try:
        r = requests.get(
            f"https://api.dexscreener.com/latest/dex/tokens/{token_addr}",
            timeout=8)
        if r.status_code == 200:
            pairs = r.json().get("pairs", [])
            if pairs:
                best = max(pairs,
                           key=lambda x: x.get("volume", {}).get("h24", 0))
                return float(best.get("priceUsd", 0) or 0)
    except Exception as e:
        print(f"[TOKEN PRICE ERR] {token_addr[:8]} {e}")
    return 0.0


def log_error(conn: sqlite3.Connection, component: str,
              message: str, detail: str = ""):
    try:
        c = conn.cursor()
        c.execute(
            "INSERT INTO errors (ts, component, message, detail) "
            "VALUES (?,?,?,?)",
            (time.time(), component, message, detail))
        conn.commit()
    except Exception:
        pass


def send_tg(msg: str):
    """Kirim notifikasi Telegram. Non-blocking."""
    if not BOT_TOKEN or not CHAT_ID:
        return
    try:
        requests.post(
            f"https://api.telegram.org/bot{BOT_TOKEN}/sendMessage",
            json={"chat_id": CHAT_ID, "text": msg,
                  "parse_mode": "HTML",
                  "disable_web_page_preview": True},
            timeout=10,
        )
    except Exception as e:
        print(f"[TG ERR] {e}")


GRADE_ORDER = {"A+": 5, "A": 4, "B": 3, "C": 2, "D": 1}


